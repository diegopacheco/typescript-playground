{
  "compilerOptions": {
    "allowImportingTsExtensions": true,
    "target": "ES2021",
    "module": "ES2020",
    "lib": ["es2021", "DOM", "DOM.Iterable"],
    "jsx": "react-jsx",
    "jsxImportSource": "@builder.io/qwik",
    "strict": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "moduleResolution": "node",
    "esModuleInterop": true,
    "skipLibCheck": true,
    "incremental": true,
    "outDir": "tmp",
    "noEmit": true,
    "types": ["vite/client"]
  },
  "include": ["src"]
}
